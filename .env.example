# ==============================================
# Adaptive Learning Decision Engine
# Environment Configuration Template
# ==============================================

# ==============================================
# ENVIRONMENT
# ==============================================
ENVIRONMENT=development  # Options: development, staging, production
NODE_ENV=development

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
POSTGRES_DB=adaptive_learning
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full database URL (constructed from above or set directly)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/adaptive_learning

# ==============================================
# BACKEND CONFIGURATION
# ==============================================
# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production-use-strong-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ==============================================
# FRONTEND CONFIGURATION
# ==============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Adaptive Learning System
NEXT_PUBLIC_ENABLE_PWA=true

# ==============================================
# SYNC CONFIGURATION
# ==============================================
SYNC_RETRY_MAX_ATTEMPTS=5
SYNC_RETRY_BACKOFF_SECONDS=2
SYNC_BATCH_SIZE=100

# ==============================================
# PERFORMANCE SETTINGS
# ==============================================
# Decision Engine
DECISION_ENGINE_CACHE_TTL_MINUTES=5
DECISION_ENGINE_TIMEOUT_MS=200

# Database Connection Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ==============================================
# LOGGING
# ==============================================
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # Options: json, text

# ==============================================
# SECURITY
# ==============================================
# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true

# Password Requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=false

# ==============================================
# FEATURE FLAGS
# ==============================================
ENABLE_TEACHER_ANALYTICS=true
ENABLE_OFFLINE_SYNC=true
ENABLE_PWA=true
ENABLE_PROPERTY_TESTING=true

# ==============================================
# MONITORING & HEALTH CHECKS
# ==============================================
HEALTH_CHECK_INTERVAL_SECONDS=30
ENABLE_METRICS=true
METRICS_PORT=9090
